generator client { 
  provider = "prisma-client-js" 
}  

datasource db {  
  provider  = "postgresql"  
  url       = env("DATABASE_URL")  
  directUrl = env("DIRECT_URL")  
} 
  
model User {  
  id                  String    @id @default(cuid())  
  googleId            String    @unique @map("google_id")  
  email               String    @unique  
  name                String  
  profilePicture      String?   @map("profile_picture")  
  whatsappNumber      String?   @unique @map("whatsapp_number")  
  spreadsheetId       String?   @map("spreadsheet_id")  
  googleDriveFolderId String?   @map("google_drive_folder_id")  
  currencyCode        String    @default("IDR") @map("currency_code")  
  isOnboarded         Boolean   @default(false) @map("is_onboarded")  
  createdAt           DateTime  @default(now()) @map("created_at")  
  updatedAt           DateTime  @updatedAt @map("updated_at")  
  oauthToken          OAuthToken?  
  accounts            Account[]  
  transactions        Transaction[]  
  budgets             Budget[]  
  transactionSessions TransactionSession[]  
  @@map("users")  
} 
  
model OAuthToken {  
  id           String   @id @default(cuid())  
  userId       String   @unique @map("user_id")  
  accessToken  String   @map("access_token")  
  refreshToken String   @map("refresh_token")  
  tokenType    String   @default("Bearer") @map("token_type")  
  scope        String  
  expiresAt    DateTime @map("expires_at")  
  createdAt    DateTime @default(now()) @map("created_at")  
  updatedAt    DateTime @updatedAt @map("updated_at")  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)  
  @@map("oauth_tokens")  
} 
  
model Account {  
  id             String      @id @default(cuid())  
  userId         String      @map("user_id")  
  name           String  
  type           AccountType  
  initialBalance Decimal     @default(0) @map("initial_balance") @db.Decimal(15,2)  
  currentBalance Decimal     @default(0) @map("current_balance") @db.Decimal(15,2)  
  color          String?  
  icon           String?  
  isActive       Boolean     @default(true) @map("is_active")  
  createdAt      DateTime    @default(now()) @map("created_at")  
  updatedAt      DateTime    @updatedAt @map("updated_at")  
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)  
  transactions   Transaction[]  
  @@map("accounts")  
} 

enum AccountType { 
  BANK  
  E_WALLET  
  CASH  
  CREDIT_CARD  
  INVESTMENT 
}  
  
model Category {  
  id           String       @id @default(cuid())  
  name         String       @unique  
  icon         String?  
  color        String?  
  type         CategoryType  
  isSystem     Boolean      @default(false) @map("is_system")  
  keywords     String[]  
  createdAt    DateTime     @default(now()) @map("created_at")  
  transactions Transaction[]  
  budgets      Budget[]  
  @@map("categories")  
} 

enum CategoryType { 
  INCOME  
  EXPENSE  
  TRANSFER 
}  
  
model Transaction {  
  id              String            @id @default(cuid())  
  userId          String            @map("user_id")  
  accountId       String            @map("account_id")  
  categoryId      String?           @map("category_id")  
  type            TransactionType  
  amount          Decimal           @db.Decimal(15,2)  
  description     String?  
  merchantName    String?           @map("merchant_name")  
  transactionDate DateTime          @map("transaction_date")  
  source          TransactionSource @default(MANUAL_WEB)  
  rawInput        String?           @map("raw_input")  
  imageUrl        String?           @map("image_url")  
  sheetsRowIndex  Int?              @map("sheets_row_index")  
  isSynced        Boolean           @default(false) @map("is_synced")  
  isConfirmed     Boolean           @default(true) @map("is_confirmed")  
  deletedAt       DateTime?         @map("deleted_at")  
  createdAt       DateTime          @default(now()) @map("created_at")  
  updatedAt       DateTime          @updatedAt @map("updated_at")  
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)  
  account         Account           @relation(fields: [accountId], references: [id])  
  category        Category?         @relation(fields: [categoryId], references: [id])  
  items           TransactionItem[]  
  
  @@index([userId, transactionDate])  
  @@index([userId, categoryId])  
  @@index([userId, deletedAt])  
  @@map("transactions")  
} 

enum TransactionType   { 
  INCOME  
  EXPENSE  
  TRANSFER 
}  

enum TransactionSource { 
  WHATSAPP_OCR  
  WHATSAPP_TEXT  
  MANUAL_WEB 
}  
  
model TransactionItem {  
  id            String      @id @default(cuid())  
  transactionId String      @map("transaction_id")  
  name          String  
  quantity      Decimal     @default(1) @db.Decimal(8,2)  
  unitPrice     Decimal     @map("unit_price") @db.Decimal(15,2)  
  totalPrice    Decimal     @map("total_price") @db.Decimal(15,2)  
  createdAt     DateTime    @default(now()) @map("created_at")  
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)  
  @@map("transaction_items")  
} 
  
model Budget {  
  id          String   @id @default(cuid())  
  userId      String   @map("user_id")  
  categoryId  String   @map("category_id")  
  limitAmount Decimal  @map("limit_amount") @db.Decimal(15,2)  
  month       Int  
  year        Int  
  notes       String?  
  createdAt   DateTime @default(now()) @map("created_at")  
  updatedAt   DateTime @updatedAt @map("updated_at")  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)  
  category    Category @relation(fields: [categoryId], references: [id])  
  
  @@unique([userId, categoryId, month, year])  
  @@map("budgets")  
} 
  
model TransactionSession {  
  id            String        @id @default(cuid())  
  userId        String        @map("user_id")  
  waMessageId   String?       @unique @map("wa_message_id")  
  status        SessionStatus @default(PENDING)  
  extractedData Json          @map("extracted_data")  
  rawPayload    Json          @map("raw_payload")  
  expiresAt     DateTime      @map("expires_at")  
  createdAt     DateTime      @default(now()) @map("created_at")  
  updatedAt     DateTime      @updatedAt @map("updated_at")  
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)  
  
  @@index([userId, status])  
  @@map("transaction_sessions")  
} 

enum SessionStatus { 
  PENDING  
  CONFIRMED  
  EDITED  
  CANCELLED  
  EXPIRED  
  SAVED  
  FAILED 
}  
  
model ActivityLog {  
  id           String    @id @default(cuid())  
  userId       String?   @map("user_id")  
  action       String  
  module       String  
  status       LogStatus @default(SUCCESS)  
  metadata     Json?  
  errorMessage String?   @map("error_message")  
  ipAddress    String?   @map("ip_address")  
  createdAt    DateTime  @default(now()) @map("created_at")  
  
  @@index([userId, createdAt])  
  @@index([module, status])  
  @@map("activity_logs")  
} 

enum LogStatus { 
  SUCCESS  
  FAILED  
  WARNING 
} 
